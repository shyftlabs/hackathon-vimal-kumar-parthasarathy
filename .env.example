# ── FleetShield AI — copy to .env and fill in your keys ──
# .env is git-ignored; never commit real secrets.

# ── LLM (Continuum routes by model-string prefix) ──
DEFAULT_LLM_MODEL=claude-sonnet-4-5        # NOTE dashes, not dots (API id)
FALLBACK_LLM_MODEL=claude-haiku-4-5
LLM_ENABLE_FALLBACK=false
DEFAULT_LLM_TEMPERATURE=0.4
LLM_REQUEST_TIMEOUT=120
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Sessions (Redis) → native multi-turn conversation history ──
SESSION_ENABLED=true
SESSION_REDIS_HOST=localhost
SESSION_REDIS_PORT=6380                     # 6380, not 6379

# ── Off by default (need Docker/vector store) — see CLAUDE.md "Continuum upgrades" ──
MEMORY_ENABLED=false
LANGFUSE_ENABLED=false
SMART_LAYER_ENABLED=false
# Continuum's context-window map keys the dotted model name, so the dashed API id
# misses and defaults tiny; we bound history via sessions instead. Keep off.
CONTEXT_MANAGEMENT_ENABLED=false
LOG_LEVEL=INFO

# ── HTTP / MCP ──
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
FLEET_MCP_URL=http://localhost:8765/mcp

# ── Voice (optional — Smallest AI STT/TTS) ──
SMALLEST_API_KEY=

# ── Telephony (optional — real two-way dispatch call) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=+1xxxxxxxxxx                  # your Twilio number (caller)
DISPATCHER_NUMBER=+1xxxxxxxxxx              # the phone the AI calls (dispatcher)
PUBLIC_BASE_URL=                            # ngrok https URL for Twilio callbacks
TWILIO_VALIDATE_SIGNATURE=false             # set true in production (stable URL)
